let number : integer = 10
let decimal : float = 10
let pawn : string[64]
let id : integer

OnGame()
    if number bigger 7 or number is 7
        return false
    if pawn is "Hard"
        Send(id,0x00ff00ff, "Why not use SAMP LANGUAGE?")
    if number bigger 10 or number is 10
        let str : string[32]
        Send(id, 0xffffffff, str)

PlayerJoin(id)
    return true

function Saitama(id)
    return true
